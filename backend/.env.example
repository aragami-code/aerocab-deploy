# ============================================================
# AeroGo 24 Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE PAS commiter le fichier .env
# ============================================================

# ─── Application ────────────────────────────────────────────
NODE_ENV=development         # production | development
PORT=3000

# ─── Base de données ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/aerogo24

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
# JWT_EXPIRY_DAYS est géré via AppSetting jwt_expiry_days (défaut: 30)

# ─── CORS ───────────────────────────────────────────────────
# En production, liste les origines autorisées (séparées par virgule)
# OBLIGATOIRE en production (sinon démarrage bloqué)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:19006

# ─── Sécurité app ───────────────────────────────────────────
APP_KEY=change-me-32-chars-min           # Clé secrète pour GET /api/config

# ─── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── Firebase (Push Notifications) ──────────────────────────
# Option 1 (recommandée) : 3 variables individuelles
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=

# Option 2 : JSON complet en une seule variable
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── SMS : Twilio ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890          # Numéro d'expéditeur E.164

# ─── SMS : Orange Cameroun ───────────────────────────────────
ORANGE_CM_CLIENT_ID=
ORANGE_CM_CLIENT_SECRET=
ORANGE_CM_SENDER_ADDRESS=tel:+237XXXXXXXXX

# ─── SMS : Africa's Talking ──────────────────────────────────
AT_API_KEY=
AT_USERNAME=sandbox                      # 'sandbox' pour les tests
AT_SENDER_ID=                            # optionnel

# ─── Email : SendGrid ────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@aerogo24.com

# ─── Email : SMTP ────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587                            # 465 pour SSL, 587 pour STARTTLS
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@aerogo24.com

# ─── Paiements : CinetPay ────────────────────────────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
# URLs optionnelles (fallback sur URLs officielles CinetPay)
# CINETPAY_URL=https://api-checkout.cinetpay.com/v2/payment
# CINETPAY_CHECK_URL=https://api-checkout.cinetpay.com/v2/payment/check

# ─── Vols : FlightRadar24 ────────────────────────────────────
FLIGHT_RADAR_API_URL=https://fr24api.flightradar24.com/api/live/flight-positions/full
FLIGHT_RADAR_API_KEY=

# ─── Deeplinks ──────────────────────────────────────────────
# Schéma utilisé pour les retours de paiement et Google OAuth
PAYMENT_RETURN_SCHEME=aerogo24           # ex: aerogo24://payment-return

# ─── Dev / Debug ────────────────────────────────────────────
FORCE_OTP_LOG=false                      # true = log OTP en clair (DEV uniquement)
