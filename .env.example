# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://aerocab:aerocab_dev@localhost:5432/aerocab"

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN="*"

# ─── SMS (OTP) ───────────────────────────────────────────────
# Twilio
SMS_ACCOUNT_SID=""
SMS_AUTH_TOKEN=""
SMS_FROM_NUMBER=""
# ou autre provider
SMS_API_KEY=""

# ─── Flights ─────────────────────────────────────────────────
AVIATIONSTACK_KEY=""

# ─── Payments (CinetPay) ─────────────────────────────────────
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""
